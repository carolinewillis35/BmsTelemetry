<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 hover:shadow-md transition-shadow duration-200">
    <!-- Header -->
    <div class="flex items-center justify-between mb-4 pb-2 border-b border-gray-100">
        <h3 class="text-lg font-semibold text-gray-900">
            @BmsHandler.DeviceType
        </h3>

        <StatusIcon Connection="@BmsHandler.Connection" />
    </div>

    <!-- Body -->
    <div class="space-y-2">
        <p class="text-sm">
            <span class="font-medium text-gray-700">IP:</span> @BmsHandler.DeviceIP
        </p>

        <p class="text-sm">
            <span class="font-medium text-gray-700">Status:</span> @BmsHandler.Status
        </p>

        <div class="flex justify-center gap-4 pt-3">
            <button
            class="rounded-lg py-1.5 px-4 text-sm font-medium transition-colors @(BmsHandler.Status == BmsHandlerStatus.Polling ? "bg-gray-200 text-gray-600 cursor-not-allowed" : "bg-green-500 text-white hover:bg-green-600")">Start</button>

            <button
            class="rounded-lg py-1.5 px-4 text-sm font-medium transition-colors @(BmsHandler.Status == BmsHandlerStatus.Stopped ? "bg-gray-200 text-gray-600 cursor-not-allowed" : "bg-red-500 text-white hover:bg-red-600")">Stop</button>
        </div>
    </div>
</div>

@code {
    [Parameter] public IBmsHandler BmsHandler { get; set; } = default!;

    protected override void OnInitialized()
    {
        BmsHandler.OnStatusChanged += HandleStatusChanged;
    }

    private void HandleStatusChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        BmsHandler.OnStatusChanged -= HandleStatusChanged;
    }
}
