<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 hover:shadow-md transition-shadow duration-200">
    <!-- Header -->
    <div class="flex items-center justify-between mb-3">
        <h3 class="text-lg font-semibold text-gray-900">
            @BmsHandler.DeviceType
        </h3>

        <!-- Status badge placeholder -->
        <div class="flex items-center gap-2">
            <div class="w-3 h-3 rounded-full @(BmsHandler.Connection == ConnectionStatus.Connected ? "bg-green-500" : "bg-red-500")"></div>
            <span class="text-sm text-gray-600">@BmsHandler.Status</span>
        </div>
    </div>

    <!-- Body -->
    <div class="space-y-1">
        <p class="text-sm text-gray-500">
            <span class="font-medium text-gray-700">IP:</span> @BmsHandler.DeviceIP
        </p>

        <p class="text-sm text-gray-500">
            <span class="font-medium text-gray-700">Fails:</span> @BmsHandler.ConsecutiveFailures
        </p>
    </div>
</div>

@code {
    [Parameter] public IBmsHandler BmsHandler { get; set; } = default!;

    protected override void OnInitialized()
    {
        BmsHandler.OnStatusChanged += HandleStatusChanged;
    }

    private void HandleStatusChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        BmsHandler.OnStatusChanged -= HandleStatusChanged;
    }
}
