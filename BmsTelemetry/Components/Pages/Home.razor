@page "/"
@rendermode InteractiveServer
@inject IBmsHandlerRegistry BmsHandlerRegistry

<div class="space-y-8">

    <!-- Page Header -->
    <div class="border-b pb-4">
        <h1 class="text-3xl font-semibold tracking-tight">BMS Network</h1>
        <p class="text-gray-500">Overview of all BMS handlers</p>
    </div>

    <!-- Handler Cards -->
    @if (handlers == null)
    {
        <p>Loading...</p>
    }
    else
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var handler in handlers)
            {
                <HandlerCard BmsHandler="handler" />
            }
        </div>
    }

    <!-- Future Azure Information Section -->
    <div class="border-b pb-4 pt-10">
        <h2 class="text-2xl font-semibold tracking-tight">Cloud Information</h2>
        <p class="text-gray-500">Cloud-connected IoT device overview</p>
    </div>

    <div>
        <IotDeviceCard />
    </div>

</div>

@code {
    private IReadOnlyCollection<IBmsHandler>? handlers;

    protected override void OnInitialized()
    {
        handlers = BmsHandlerRegistry.GetHandlers();
    }
}
